<UserControl
    x:Class="DariaTech.PcDoctor.UI.Controls.RadialGauge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MinWidth="150" MinHeight="150">
    <Grid x:Name="Root">
        <Path x:Name="TrackPath" StrokeThickness="12"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
              Stroke="#33FFFFFF" />
        <Path x:Name="ValuePath" StrokeThickness="12"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
              Stroke="#2FA86A" />
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="ValueLabel" HorizontalAlignment="Center"
                       FontSize="28" FontWeight="SemiBold" Foreground="White" Text="—" />
            <TextBlock x:Name="CaptionLabel" HorizontalAlignment="Center"
                       FontSize="12" Foreground="#9FC9BC" Margin="0,2,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
